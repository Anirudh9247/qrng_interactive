# Database configuration
# Example: sqlite:///./qrng.db or postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./qrng.db

# Secret key for session/JWT/CSRF signing
# Generate securely using: openssl rand -hex 32
# Do NOT commit real secrets to version control
# Use environment variables or secret manager in production
SECRET_KEY=your_secure_secret_key_here_generate_with_openssl_rand_hex_32

# Backend server configuration
BACKEND_URL=http://localhost:8000

# CORS allowed origins (comma-separated or single URL)
CORS_ORIGINS=http://localhost:3000
