{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run FastAPI Backend",
      "type": "shell",
      "command": "uvicorn app.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "Run Next.js Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "new"
      }
    },
    {
      "label": "Start Full QRNG Project",
      "dependsOn": [
        "Run FastAPI Backend",
        "Run Next.js Frontend"
      ]
    }
  ]
}